<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="C:/Users/pc/Downloads/dataEl.db" readonly="0" foreign_keys="1" case_sensitive_like="0" temp_store="0" wal_autocheckpoint="1000" synchronous="2"/><attached/><window><main_tabs open="structure browser pragmas query" current="1"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="1659"/><column_width id="4" width="0"/><expanded_item id="0" parent="1"/><expanded_item id="1" parent="1"/><expanded_item id="2" parent="1"/><expanded_item id="3" parent="1"/></tab_structure><tab_browse><table title="topic" custom_title="0" dock_id="5" table="4,5:maintopic"/><dock_state state=""/><default_encoding codec=""/><browse_table_settings><table schema="main" name="grammar_exercise" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="29"/><column index="2" value="55"/><column index="3" value="35"/><column index="4" value="129"/><column index="5" value="95"/><column index="6" value="93"/><column index="7" value="90"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="sqlite_sequence" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="39"/><column index="2" value="29"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="story" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="31"/><column index="2" value="55"/><column index="3" value="300"/><column index="4" value="300"/><column index="5" value="288"/><column index="6" value="300"/><column index="7" value="234"/><column index="8" value="226"/><column index="9" value="300"/><column index="10" value="300"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="topic" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="29"/><column index="2" value="35"/><column index="3" value="300"/><column index="4" value="74"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (1, 1, 'A1', 'Tôi có hai anh trai.', 'I have two older brothers.', 'Present Simple', 'Dùng thì hiện tại đơn để nói về sự thật, mối quan hệ gia đình không thay đổi theo thời gian.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (2, 1, 'A1', 'Mẹ tôi nấu ăn rất ngon.', 'My mother cooks very well.', 'Present Simple', 'Chủ ngữ ''mẹ tôi'' (số ít, ngôi thứ 3) nên động từ ''cook'' thêm ''s'' -&gt; cooks.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (3, 1, 'A1', 'Bố tôi làm việc ở ngân hàng.', 'My father works at a bank.', 'Present Simple', 'Diễn tả thói quen/nghề nghiệp, chủ ngữ ngôi 3 số ít nên động từ thêm ''s''.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (4, 2, 'A1', 'Tôi thức dậy lúc 6 giờ sáng.', 'I wake up at 6 AM.', 'Present Simple', 'Dùng hiện tại đơn để nói về thói quen lặp lại hàng ngày, dùng giới từ ''at'' với giờ cụ thể.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (5, 2, 'A1', 'Cô ấy đi ngủ lúc 10 giờ tối.', 'She goes to bed at 10 PM.', 'Present Simple', 'Chủ ngữ ''she'' ngôi 3 số ít nên ''go'' chuyển thành ''goes''.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (6, 2, 'A1', 'Chúng tôi ăn sáng cùng nhau.', 'We have breakfast together.', 'Present Simple', '''Have breakfast'' là cụm cố định nghĩa ''ăn sáng'', không cần thêm ''s'' vì chủ ngữ là ''we''.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (7, 3, 'A1', 'Tôi thích ăn phở.', 'I like eating pho.', 'Present Simple', 'Động từ ''like'' diễn tả sở thích, có thể theo sau bằng V-ing (eating).');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (8, 3, 'A1', 'Anh ấy không ăn thịt.', 'He doesn''t eat meat.', 'Present Simple', 'Câu phủ định thì hiện tại đơn với chủ ngữ ngôi 3 số ít dùng trợ động từ ''doesn''t''.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (9, 3, 'A1', 'Bà tôi nấu bữa tối mỗi ngày.', 'My grandmother cooks dinner every day.', 'Present Simple', '''Every day'' là dấu hiệu nhận biết thì hiện tại đơn, chủ ngữ ngôi 3 số ít nên ''cook'' thêm ''s''.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (10, 4, 'A1', 'Chúng tôi đi du lịch vào mùa hè.', 'We travel in the summer.', 'Present Simple', 'Diễn tả thói quen lặp lại theo mùa, dùng giới từ ''in'' với mùa.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (11, 4, 'A1', 'Cô ấy thích đi biển.', 'She likes going to the beach.', 'Present Simple', 'Chủ ngữ ngôi 3 số ít ''she'' nên ''like'' thêm ''s'' thành ''likes''.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (12, 4, 'A1', 'Anh ấy đi làm bằng xe buýt.', 'He goes to work by bus.', 'Present Simple', '''Go to work'' diễn tả thói quen, ''by bus'' chỉ phương tiện di chuyển.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (13, 5, 'A1', 'Tôi làm việc tám giờ mỗi ngày.', 'I work eight hours a day.', 'Present Simple', 'Diễn tả thói quen công việc lặp lại, chủ ngữ ''I'' không thêm ''s'' cho động từ.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (14, 5, 'A1', 'Cô ấy là giáo viên.', 'She is a teacher.', 'Present Simple', 'Động từ ''to be'' với chủ ngữ ''she'' chia thành ''is''.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (15, 5, 'A1', 'Anh ấy bắt đầu làm việc lúc 8 giờ.', 'He starts work at 8 o''clock.', 'Present Simple', 'Chủ ngữ ngôi 3 số ít nên động từ ''start'' thêm ''s''.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (16, 6, 'A1', 'Tôi tập thể dục mỗi sáng.', 'I exercise every morning.', 'Present Simple', '''Every morning'' là dấu hiệu của thì hiện tại đơn, diễn tả thói quen.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (17, 6, 'A1', 'Anh ấy uống nhiều nước.', 'He drinks a lot of water.', 'Present Simple', 'Chủ ngữ ngôi 3 số ít nên ''drink'' thêm ''s'' thành ''drinks''.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (18, 6, 'A1', 'Cô ấy chạy bộ ba lần một tuần.', 'She runs three times a week.', 'Present Simple', '''Three times a week'' chỉ tần suất, phù hợp với thì hiện tại đơn.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (19, 7, 'A1', 'Tôi dùng điện thoại mỗi ngày.', 'I use my phone every day.', 'Present Simple', 'Diễn tả thói quen sử dụng công nghệ hàng ngày.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (20, 7, 'A1', 'Anh ấy không thích mạng xã hội.', 'He doesn''t like social media.', 'Present Simple', 'Câu phủ định với ''doesn''t'' vì chủ ngữ ngôi 3 số ít.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (21, 7, 'A1', 'Chúng tôi xem phim trên máy tính.', 'We watch movies on the computer.', 'Present Simple', 'Chủ ngữ ''we'' không cần thêm ''s'' cho động từ.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (22, 8, 'A1', 'Tôi thích đọc sách.', 'I like reading books.', 'Present Simple', 'Động từ ''like'' theo sau bởi V-ing để diễn tả sở thích.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (23, 8, 'A1', 'Cô ấy chơi đàn piano.', 'She plays the piano.', 'Present Simple', 'Chủ ngữ ngôi 3 số ít nên ''play'' thêm ''s'' thành ''plays''.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (24, 8, 'A1', 'Anh ấy vẽ tranh vào cuối tuần.', 'He paints on weekends.', 'Present Simple', '''On weekends'' chỉ thời gian lặp lại, dùng giới từ ''on''.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (25, 9, 'A1', 'Chúng tôi tái chế rác mỗi tuần.', 'We recycle trash every week.', 'Present Simple', 'Diễn tả hành động lặp lại có ý thức bảo vệ môi trường.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (26, 9, 'A1', 'Cô ấy không dùng túi nhựa.', 'She doesn''t use plastic bags.', 'Present Simple', 'Câu phủ định với ''doesn''t'' vì chủ ngữ ngôi 3 số ít.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (27, 9, 'A1', 'Anh ấy trồng cây trong vườn.', 'He plants trees in the garden.', 'Present Simple', 'Chủ ngữ ngôi 3 số ít nên ''plant'' thêm ''s'' thành ''plants''.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (28, 10, 'A1', 'Tôi học tiếng Anh mỗi ngày.', 'I study English every day.', 'Present Simple', '''Every day'' là dấu hiệu nhận biết thì hiện tại đơn.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (29, 10, 'A1', 'Cô ấy đi học lúc 7 giờ.', 'She goes to school at 7 o''clock.', 'Present Simple', 'Chủ ngữ ngôi 3 số ít nên ''go'' chuyển thành ''goes''.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (30, 10, 'A1', 'Anh ấy làm bài tập về nhà.', 'He does his homework.', 'Present Simple', 'Chủ ngữ ngôi 3 số ít nên ''do'' chuyển thành ''does''.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (31, 11, 'A2', 'Tôi đang nói chuyện với mẹ tôi.', 'I am talking to my mother.', 'Present Continuous', 'Hành động đang xảy ra ngay lúc nói, dùng am/is/are + V-ing.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (32, 11, 'A2', 'Chúng tôi đã đi thăm ông bà vào tuần trước.', 'We visited our grandparents last week.', 'Past Simple', '''Last week'' là dấu hiệu của thì quá khứ đơn, ''visit'' -&gt; ''visited''.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (33, 11, 'A2', 'Anh ấy đang giúp em gái làm bài tập.', 'He is helping his sister with homework.', 'Present Continuous', 'Chủ ngữ ''he'' dùng ''is'' + V-ing để diễn tả hành động đang diễn ra.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (34, 12, 'A2', 'Cô ấy đang chuẩn bị bữa tối.', 'She is preparing dinner.', 'Present Continuous', 'Hành động đang diễn ra ngay lúc nói, chủ ngữ ''she'' dùng ''is''.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (35, 12, 'A2', 'Tôi đã dậy sớm hôm qua.', 'I woke up early yesterday.', 'Past Simple', '''Yesterday'' là dấu hiệu quá khứ đơn, ''wake up'' là động từ bất quy tắc -&gt; ''woke up''.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (36, 12, 'A2', 'Anh ấy đang đọc báo bây giờ.', 'He is reading the newspaper now.', 'Present Continuous', '''Now'' là dấu hiệu của hiện tại tiếp diễn.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (37, 13, 'A2', 'Tôi đang nấu món phở.', 'I am cooking pho.', 'Present Continuous', 'Chủ ngữ ''I'' dùng ''am'' + V-ing.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (38, 13, 'A2', 'Cô ấy đã làm bánh vào chủ nhật.', 'She made a cake on Sunday.', 'Past Simple', '''Make'' là động từ bất quy tắc, quá khứ là ''made''.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (39, 13, 'A2', 'Chúng tôi đang ăn tối.', 'We are having dinner.', 'Present Continuous', 'Chủ ngữ ''we'' dùng ''are'' + V-ing.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (40, 14, 'A2', 'Anh ấy đang đóng gói hành lý.', 'He is packing his luggage.', 'Present Continuous', 'Hành động đang diễn ra, chủ ngữ ngôi 3 số ít dùng ''is''.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (41, 14, 'A2', 'Chúng tôi đã đi Đà Lạt năm ngoái.', 'We went to Da Lat last year.', 'Past Simple', '''Go'' là động từ bất quy tắc, quá khứ là ''went''; ''last year'' là dấu hiệu quá khứ đơn.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (42, 14, 'A2', 'Cô ấy đang chụp ảnh ở bãi biển.', 'She is taking photos at the beach.', 'Present Continuous', '''Take'' + V-ing thành ''taking'' khi chia thì tiếp diễn.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (43, 15, 'A2', 'Tôi đang viết báo cáo.', 'I am writing a report.', 'Present Continuous', '''Write'' bỏ ''e'' trước khi thêm ''-ing'' thành ''writing''.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (44, 15, 'A2', 'Anh ấy đã xin việc tuần trước.', 'He applied for a job last week.', 'Past Simple', '''Apply'' kết thúc bằng phụ âm + ''y'' nên thêm ''-ed'' trực tiếp thành ''applied''.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (45, 15, 'A2', 'Cô ấy đang họp với khách hàng.', 'She is meeting with a client.', 'Present Continuous', 'Hành động đang diễn ra tại thời điểm nói.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (46, 16, 'A2', 'Tôi đang tập yoga.', 'I am doing yoga.', 'Present Continuous', '''Do'' + ''-ing'' thành ''doing''.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (47, 16, 'A2', 'Anh ấy đã bị cảm lạnh tuần trước.', 'He caught a cold last week.', 'Past Simple', '''Catch'' là động từ bất quy tắc, quá khứ là ''caught''.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (48, 16, 'A2', 'Cô ấy đang đi bộ trong công viên.', 'She is walking in the park.', 'Present Continuous', 'Hành động đang diễn ra ngay lúc nói.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (49, 17, 'A2', 'Tôi đang tải một ứng dụng mới.', 'I am downloading a new app.', 'Present Continuous', '''Download'' + ''-ing'' thành ''downloading''.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (50, 17, 'A2', 'Anh ấy đã mua điện thoại mới hôm qua.', 'He bought a new phone yesterday.', 'Past Simple', '''Buy'' là động từ bất quy tắc, quá khứ là ''bought''.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (51, 17, 'A2', 'Cô ấy đang gửi email cho sếp.', 'She is sending an email to her boss.', 'Present Continuous', '''Send'' + ''-ing'' thành ''sending''.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (52, 18, 'A2', 'Tôi đang học chơi guitar.', 'I am learning to play the guitar.', 'Present Continuous', 'Diễn tả hành động đang trong quá trình học, chưa hoàn thành.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (53, 18, 'A2', 'Cô ấy đã tham gia một lớp vẽ tháng trước.', 'She joined a painting class last month.', 'Past Simple', '''Last month'' là dấu hiệu quá khứ đơn, ''join'' thêm ''-ed'' thành ''joined''.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (54, 18, 'A2', 'Anh ấy đang xem một bộ phim.', 'He is watching a movie.', 'Present Continuous', 'Hành động đang diễn ra ngay lúc nói.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (55, 19, 'A2', 'Chúng tôi đang dọn dẹp bãi biển.', 'We are cleaning the beach.', 'Present Continuous', 'Chủ ngữ ''we'' dùng ''are'' + V-ing.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (56, 19, 'A2', 'Cô ấy đã trồng mười cây tuần trước.', 'She planted ten trees last week.', 'Past Simple', '''Plant'' thêm ''-ed'' thành ''planted'', ''last week'' là dấu hiệu quá khứ đơn.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (57, 19, 'A2', 'Anh ấy đang tiết kiệm điện.', 'He is saving electricity.', 'Present Continuous', '''Save'' bỏ ''e'' trước khi thêm ''-ing'' thành ''saving''.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (58, 20, 'A2', 'Tôi đang chuẩn bị cho kỳ thi.', 'I am preparing for the exam.', 'Present Continuous', 'Hành động đang diễn ra trong khoảng thời gian hiện tại.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (59, 20, 'A2', 'Anh ấy đã đậu kỳ thi tháng trước.', 'He passed the exam last month.', 'Past Simple', '''Pass'' thêm ''-ed'' thành ''passed'', ''last month'' là dấu hiệu quá khứ đơn.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (60, 20, 'A2', 'Cô ấy đang viết luận.', 'She is writing an essay.', 'Present Continuous', '''Write'' bỏ ''e'' trước khi thêm ''-ing'' thành ''writing''.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (61, 21, 'B1', 'Tôi đã sống với bố mẹ mười năm rồi.', 'I have lived with my parents for ten years.', 'Present Perfect', 'Dùng ''have/has + V3'' với ''for + khoảng thời gian'' để diễn tả hành động bắt đầu trong quá khứ và còn tiếp diễn.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (62, 21, 'B1', 'Nếu tôi có thời gian, tôi sẽ thăm ông bà vào cuối tuần.', 'If I have time, I will visit my grandparents this weekend.', 'First Conditional', 'Câu điều kiện loại 1: mệnh đề if dùng hiện tại đơn, mệnh đề chính dùng ''will + V''.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (63, 22, 'B1', 'Cô ấy đã thay đổi thói quen buổi sáng của mình.', 'She has changed her morning routine.', 'Present Perfect', 'Hành động xảy ra trong quá khứ nhưng kết quả còn ảnh hưởng đến hiện tại, không nêu rõ thời gian cụ thể.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (64, 22, 'B1', 'Nếu tôi ngủ sớm, tôi sẽ dậy sớm hơn.', 'If I sleep early, I will wake up earlier.', 'First Conditional', 'Mệnh đề điều kiện (if) chia hiện tại đơn, mệnh đề kết quả chia ''will + V''.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (65, 23, 'B1', 'Tôi chưa bao giờ nấu món này trước đây.', 'I have never cooked this dish before.', 'Present Perfect', '''Never'' + ''before'' thường đi cùng thì hiện tại hoàn thành để nhấn mạnh kinh nghiệm chưa từng có.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (66, 23, 'B1', 'Nếu bạn thêm đường, món ăn sẽ ngọt hơn.', 'If you add sugar, the dish will be sweeter.', 'First Conditional', 'Diễn tả kết quả có khả năng xảy ra cao nếu điều kiện được thực hiện.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (67, 24, 'B1', 'Chúng tôi đã đến thăm năm quốc gia rồi.', 'We have visited five countries so far.', 'Present Perfect', '''So far'' đi cùng hiện tại hoàn thành để nói về trải nghiệm tính đến hiện tại.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (68, 24, 'B1', 'Nếu thời tiết đẹp, chúng tôi sẽ đi leo núi.', 'If the weather is nice, we will go hiking.', 'First Conditional', 'Điều kiện có thể xảy ra ở tương lai gần, dùng cấu trúc if + hiện tại đơn, will + V.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (69, 25, 'B1', 'Anh ấy đã làm việc ở công ty này ba năm rồi.', 'He has worked at this company for three years.', 'Present Perfect', '''For + khoảng thời gian'' đi cùng hiện tại hoàn thành diễn tả hành động kéo dài đến hiện tại.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (70, 25, 'B1', 'Nếu tôi hoàn thành dự án đúng hạn, tôi sẽ được thăng chức.', 'If I finish the project on time, I will get promoted.', 'First Conditional', 'Mệnh đề chính ở dạng bị động ''will be/get promoted'' vẫn giữ cấu trúc will + V.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (71, 26, 'B1', 'Cô ấy đã đi tập gym được sáu tháng rồi.', 'She has been going to the gym for six months.', 'Present Perfect Continuous', 'Nhấn mạnh hành động lặp lại/kéo dài liên tục từ quá khứ đến hiện tại, dùng have/has been + V-ing.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (72, 26, 'B1', 'Nếu bạn ngủ đủ giấc, bạn sẽ khỏe hơn.', 'If you get enough sleep, you will be healthier.', 'First Conditional', 'Kết quả tất yếu nếu điều kiện được đáp ứng, dùng will + tính từ so sánh hơn.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (73, 27, 'B1', 'Công nghệ đã thay đổi cách chúng ta sống rất nhiều.', 'Technology has changed the way we live a lot.', 'Present Perfect', 'Không nêu thời gian cụ thể, nhấn mạnh kết quả/ảnh hưởng đến hiện tại.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (74, 27, 'B1', 'Nếu giá giảm, tôi sẽ mua chiếc laptop đó.', 'If the price drops, I will buy that laptop.', 'First Conditional', 'Cấu trúc if + hiện tại đơn, mệnh đề chính will + V nguyên thể.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (75, 28, 'B1', 'Tôi đã chơi bóng đá từ khi còn nhỏ.', 'I have played football since I was young.', 'Present Perfect', '''Since'' + thời điểm trong quá khứ thường đi cùng thì hiện tại hoàn thành.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (76, 28, 'B1', 'Nếu tôi có nhiều thời gian hơn, tôi sẽ học vẽ.', 'If I have more free time, I will learn painting.', 'First Conditional', 'Điều kiện có khả năng xảy ra, mệnh đề chính diễn tả kế hoạch tương lai.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (77, 29, 'B1', 'Chính phủ đã đưa ra nhiều chính sách bảo vệ môi trường.', 'The government has introduced many environmental policies.', 'Present Perfect', 'Hành động trong quá khứ có ảnh hưởng/kết quả đến hiện tại, không cần mốc thời gian cụ thể.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (78, 29, 'B1', 'Nếu mọi người tái chế nhiều hơn, ô nhiễm sẽ giảm.', 'If people recycle more, pollution will decrease.', 'First Conditional', 'Diễn tả hệ quả tất yếu mang tính dự đoán trong tương lai.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (79, 30, 'B1', 'Tôi đã học tiếng Anh được năm năm rồi.', 'I have studied English for five years.', 'Present Perfect', '''For + khoảng thời gian'' với hiện tại hoàn thành diễn tả hành động kéo dài đến hiện tại.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (80, 30, 'B1', 'Nếu bạn học chăm chỉ, bạn sẽ đạt điểm cao.', 'If you study hard, you will get high marks.', 'First Conditional', 'Cấu trúc câu điều kiện loại 1 cơ bản, thể hiện kết quả có khả năng xảy ra cao.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (81, 31, 'B2', 'Nếu tôi biết trước, tôi đã không nói điều đó với mẹ.', 'If I had known, I wouldn''t have said that to my mother.', 'Third Conditional', 'Câu điều kiện loại 3 diễn tả giả định trái với quá khứ: if + had + V3, would have + V3.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (82, 31, 'B2', 'Mối quan hệ giữa các thành viên trong gia đình đã bị ảnh hưởng bởi công nghệ.', 'The relationships between family members have been affected by technology.', 'Passive Voice', 'Câu bị động thì hiện tại hoàn thành: have/has been + V3, nhấn mạnh vào đối tượng bị tác động.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (83, 32, 'B2', 'Nếu tôi có nhiều thời gian hơn, tôi sẽ tổ chức lại thói quen hàng ngày của mình.', 'If I had more time, I would reorganize my daily routine.', 'Second Conditional', 'Câu điều kiện loại 2 diễn tả giả định không thật ở hiện tại: if + V2/were, would + V.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (84, 32, 'B2', 'Lịch trình của tôi được lên kế hoạch mỗi tuần.', 'My schedule is planned every week.', 'Passive Voice', 'Câu bị động thì hiện tại đơn: is/am/are + V3, nhấn mạnh hành động được thực hiện lên chủ thể.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (85, 33, 'B2', 'Món ăn này được nấu bởi đầu bếp nổi tiếng.', 'This dish was cooked by a famous chef.', 'Passive Voice', 'Câu bị động thì quá khứ đơn: was/were + V3, kèm ''by'' để chỉ tác nhân thực hiện.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (86, 33, 'B2', 'Nếu tôi là đầu bếp, tôi sẽ sáng tạo ra những món ăn mới.', 'If I were a chef, I would create new dishes.', 'Second Conditional', 'Với động từ ''to be'' ở câu điều kiện loại 2, luôn dùng ''were'' cho mọi chủ ngữ.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (87, 34, 'B2', 'Chuyến đi đã bị hủy do thời tiết xấu.', 'The trip was canceled due to bad weather.', 'Passive Voice', 'Câu bị động quá khứ đơn nhấn mạnh vào sự việc xảy ra (''the trip''), không cần nêu ai hủy.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (88, 34, 'B2', 'Nếu tôi có nhiều tiền hơn, tôi sẽ đi du lịch vòng quanh thế giới.', 'If I had more money, I would travel around the world.', 'Second Conditional', 'Giả định không có thật ở hiện tại, dùng if + quá khứ đơn, would + V.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (89, 35, 'B2', 'Dự án đã được hoàn thành trước thời hạn.', 'The project was completed ahead of schedule.', 'Passive Voice', 'Câu bị động quá khứ đơn, nhấn mạnh kết quả công việc hơn là người thực hiện.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (90, 35, 'B2', 'Nếu tôi không nghỉ việc, tôi có thể đã được thăng chức.', 'If I hadn''t quit my job, I might have been promoted.', 'Third Conditional', 'Câu điều kiện loại 3 kết hợp bị động: might have been + V3, diễn tả khả năng giả định trong quá khứ.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (91, 36, 'B2', 'Sức khỏe của anh ấy đã được cải thiện đáng kể.', 'His health has been significantly improved.', 'Passive Voice', 'Câu bị động thì hiện tại hoàn thành: have/has been + V3.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (92, 36, 'B2', 'Nếu tôi biết sớm hơn, tôi đã thay đổi chế độ ăn của mình.', 'If I had known earlier, I would have changed my diet.', 'Third Conditional', 'Giả định trái với thực tế trong quá khứ: if + had + V3, would have + V3.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (93, 37, 'B2', 'Ứng dụng này được phát triển bởi một nhóm kỹ sư trẻ.', 'This app was developed by a team of young engineers.', 'Passive Voice', 'Câu bị động quá khứ đơn có ''by'' để chỉ tác nhân thực hiện hành động.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (94, 37, 'B2', 'Nếu không có internet, cuộc sống của chúng ta sẽ rất khác.', 'If there were no internet, our lives would be very different.', 'Second Conditional', '''There were'' dùng cho giả định không thật ở hiện tại dù danh từ là số ít/không đếm được.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (95, 38, 'B2', 'Bức tranh này đã được trưng bày tại một phòng triển lãm nổi tiếng.', 'This painting has been displayed at a famous gallery.', 'Passive Voice', 'Câu bị động hiện tại hoàn thành nhấn mạnh trải nghiệm/kết quả của vật được nói đến.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (96, 38, 'B2', 'Nếu tôi có tài năng âm nhạc, tôi sẽ trở thành một nhạc sĩ.', 'If I had musical talent, I would become a musician.', 'Second Conditional', 'Giả định trái với thực tế ở hiện tại, dùng if + quá khứ đơn, would + V nguyên thể.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (97, 39, 'B2', 'Nhiều khu rừng đã bị phá hủy bởi hoạt động khai thác gỗ.', 'Many forests have been destroyed by logging activities.', 'Passive Voice', 'Câu bị động hiện tại hoàn thành, ''by'' nêu nguyên nhân/tác nhân gây ra hành động.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (98, 39, 'B2', 'Nếu chúng ta không hành động ngay, hậu quả sẽ nghiêm trọng hơn.', 'If we don''t act now, the consequences will be more serious.', 'First Conditional', 'Dù ở topic B2 nhưng vẫn dùng cấu trúc loại 1 vì đây là cảnh báo có khả năng xảy ra thực tế.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (99, 40, 'B2', 'Hệ thống giáo dục đã được cải cách trong những năm gần đây.', 'The education system has been reformed in recent years.', 'Passive Voice', 'Câu bị động hiện tại hoàn thành với ''in recent years'' chỉ khoảng thời gian gần đây.');
INSERT INTO &quot;grammar_exercise&quot; (&quot;id&quot;, &quot;topic_id&quot;, &quot;level&quot;, &quot;vietnamese_sentence&quot;, &quot;correct_answer&quot;, &quot;grammar_topic&quot;, &quot;explanation_vi&quot;) VALUES (100, 40, 'B2', 'Nếu tôi được học ở nước ngoài, tôi sẽ cải thiện tiếng Anh nhanh hơn.', 'If I studied abroad, I would improve my English faster.', 'Second Conditional', 'Giả định không thật ở hiện tại về việc học tập, dùng if + quá khứ đơn, would + V.');</sql><current_tab id="0"/></tab_sql></sqlb_project>
