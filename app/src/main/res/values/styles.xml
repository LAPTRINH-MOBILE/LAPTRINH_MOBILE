<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="TextAppearance.WordPulse.BottomNav.Active" parent="">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.WordPulse.BottomNav.Inactive" parent="">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">normal</item>
    </style>

    <style name="ShapeAppearance.WordPulse.NavIndicator" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="Widget.WordPulse.BottomNavigation.ActiveIndicator" parent="">
        <item name="android:width">46dp</item>
        <item name="android:height">30dp</item>
        <item name="android:color">#1A2196F3</item>
        <item name="marginHorizontal">0dp</item>
        <item name="shapeAppearance">@style/ShapeAppearance.WordPulse.NavIndicator</item>
    </style>
</resources>
