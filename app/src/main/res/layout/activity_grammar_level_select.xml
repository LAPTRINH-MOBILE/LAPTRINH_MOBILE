<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/grammar_level_screen_bg"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvLevelSelectTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:text="Chọn Cấp Độ Phù Hợp"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <GridLayout
            android:id="@+id/levelGrid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:alignmentMode="alignMargins"
            android:columnCount="2"
            android:rowCount="2">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLevelA1"
                android:layout_width="0dp"
                android:layout_height="166dp"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:layout_margin="6dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/grammar_level_a1_bg"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeColor="#BBDCF2"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:contentDescription="A1"
                        android:src="@drawable/ic_leaf"
                        android:tint="@color/strength_strong" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center"
                        android:text="Cấp độ A1"
                        android:textColor="@color/grammar_level_a1_text"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:gravity="center"
                        android:text="Bắt đầu"
                        android:textColor="@color/text_muted"
                        android:textSize="14sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLevelA2"
                android:layout_width="0dp"
                android:layout_height="166dp"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:layout_margin="6dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/grammar_level_a2_bg"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeColor="#CDEDD6"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:contentDescription="A2"
                        android:src="@drawable/ic_spark"
                        android:tint="#1F8F4B" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center"
                        android:text="Cấp độ A2"
                        android:textColor="@color/grammar_level_a2_text"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:gravity="center"
                        android:text="Sơ cấp"
                        android:textColor="@color/text_muted"
                        android:textSize="14sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLevelB1"
                android:layout_width="0dp"
                android:layout_height="166dp"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:layout_margin="6dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/grammar_level_b1_bg"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeColor="#F6DBB6"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:contentDescription="B1"
                        android:src="@drawable/ic_book_open"
                        android:tint="@color/grammar_level_b1_text" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center"
                        android:text="Cấp độ B1"
                        android:textColor="@color/grammar_level_b1_text"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:gravity="center"
                        android:text="Trung cấp"
                        android:textColor="@color/text_muted"
                        android:textSize="14sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLevelB2"
                android:layout_width="0dp"
                android:layout_height="166dp"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:layout_margin="6dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/grammar_level_b2_bg"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeColor="#E6D0F3"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:contentDescription="B2"
                        android:src="@drawable/ic_school"
                        android:tint="@color/grammar_level_b2_text" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center"
                        android:text="Cấp độ B2"
                        android:textColor="@color/grammar_level_b2_text"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:gravity="center"
                        android:text="Nâng cao"
                        android:textColor="@color/text_muted"
                        android:textSize="14sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </GridLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBackHome"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="20dp"
            android:text="QUAY VỀ TRANG CHỦ"
            android:textColor="@color/grammar_level_a1_text"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="@android:color/transparent"
            app:cornerRadius="8dp"
            app:rippleColor="#142E86DE"
            app:strokeColor="@color/grammar_level_a1_text"
            app:strokeWidth="1dp" />
    </LinearLayout>
</ScrollView>
